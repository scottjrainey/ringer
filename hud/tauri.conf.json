{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ringside",
  "version": "0.1.0",
  "identifier": "com.jonedwards.ringside",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Ringside",
        "width": 360,
        "height": 420,
        "minWidth": 280,
        "minHeight": 220,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "center": false
      }
    ],
    "security": {
      "csp": "default-src 'self' data: asset: http://asset.localhost 'unsafe-inline'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' asset: http://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
